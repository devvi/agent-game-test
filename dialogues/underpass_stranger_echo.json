{
  "entry_node_id": "echo_entry",
  "nodes": {
    "echo_entry": {
      "speaker": "Stranger",
      "text": "雨这么大，你不会想走太远的。",
      "on_enter": [
        { "type": "set_flag", "flag": "rain_echo_triggered", "value": true }
      ],
      "choices": [
        {
          "text": "「我知道。但我还是得走。」",
          "next_node": "echo_acknowledge",
          "effects": []
        },
        {
          "text": "「不关你的事。」",
          "next_node": "echo_deny",
          "effects": []
        },
        {
          "text": "（沉默地走过）",
          "next_node": "echo_silent",
          "effects": []
        },
        {
          "text": "「你知道我是谁，对吧。」",
          "next_node": "echo_meta_entry",
          "condition": { "type": "flag", "flag": "is_new_game_plus", "value": true },
          "effects": []
        }
      ]
    },
    "echo_acknowledge": {
      "speaker": "Stranger",
      "text": "……好。那就走吧。",
      "on_enter": [],
      "choices": [
        {
          "text": "(Continue to the station)",
          "next_node": "echo_tunnel_walk",
          "effects": [
            { "type": "slider_delta", "axis": "hope", "delta": 1.0 },
            { "type": "slider_delta", "axis": "conviction", "delta": 1.0 },
            { "type": "slider_delta", "axis": "will", "delta": 1.0 }
