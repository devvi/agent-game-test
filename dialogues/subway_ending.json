{
  "entry_node_id": "station_arrive",
  "nodes": {
    "station_arrive": {
      "speaker": "Narrator",
      "text": "The station is empty.\nThe clock reads 11:47 PM.\nA train hums below.",
      "on_enter": [],
      "choices": [
        {
          "text": "进站检票",
          "next_node": "kw_arrive",
          "effects": [],
          "condition": {
            "type": "and",
            "conditions": [
              { "type": "slider", "axis": "hope", "op": "gte", "value": 6 },
              { "type": "slider", "axis": "will", "op": "gte", "value": 5 }
            ]
          }
        },
        {
          "text": "转身走回出口",
          "next_node": "tb_arrive",
          "effects": [],
          "condition": {
            "type": "slider",
            "axis": "conviction",
            "op": "lte",
            "value": 3
          }
        },
        {
          "text": "在长椅上坐下",
          "next_node": "st_arrive",
          "effects": []
        }
      ]
    },
    "kw_arrive": {
      "speaker": "Narrator",
      "text": "The train hums in the distance.\nThe platform is quiet.\nYou hear your heartbeat.",
      "choices": [
        {
          "text": "Step to the edge.",
          "next_node": "kw_edge",
          "effects": [
            { "type": "slider_delta", "axis": "will", "delta": 0.5 }
          ]
        }
      ]
    },
    "kw_edge": {
      "speaker": "Narrator",
      "text": "The yellow line glows.\nLight at the tunnel end.\nThe wet night behind.",
      "choices": [
        {
          "text": "Look back at the city.",
          "next_node": "kw_lookback",
          "effects": []
        },
        {
          "text": "Face forward.",
          "next_node": "kw_stranger",
          "effects": [
            { "type": "slider_delta", "axis": "conviction", "delta": 0.5 }
          ]
        }
      ]
    },
    "kw_lookback": {
      "speaker": "Narrator",
      "text": "The city glitters beyond.\nThe office, the bridge, the store.\nAll behind you now.",
      "choices": [
        {
          "text": "Turn forward.",
          "next_node": "kw_stranger",
          "effects": [
            { "type": "slider_delta", "axis": "will", "delta": 0.5 }
          ]
        }
      ]
    },
    "kw_stranger": {
      "speaker": "Stranger",
      "text": "下次再见。",
      "choices": [
        {
          "text": "「下次再见。……或者说，下次再见自己。」",
          "next_node": "kw_stranger_meta",
          "condition": { "type": "flag", "flag": "stranger_revealed", "value": true },
          "effects": [
            { "type": "slider_delta", "axis": "hope", "delta": 1.0 }
          ]
        },
        {
          "text": "「再见。」",
          "next_node": "kw_train",
          "effects": [
            { "type": "slider_delta", "axis": "hope", "delta": 1.0 }
          ]
        }
      ]
    },
    "kw_train": {
      "speaker": "Narrator",
      "text": "The doors slide open.\nWarm light spills out.\nYou step inside.",
      "choices": [
        {
          "text": "Sit by the window.",
          "next_node": "kw_final",
          "effects": []
        }
      ]
    },
    "kw_final": {
      "speaker": "Narrator",
      "text": "The train pulls away.\nRain streaks past the glass.\nFor the first time, you breathe.",
