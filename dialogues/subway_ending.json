      "choices": [
        {
          "text": "Stand up.",
          "next_node": "st_stranger",
          "effects": []
        },
        {
          "text": "Stay seated.",
          "next_node": "st_stranger",
          "effects": [
            { "type": "slider_delta", "axis": "will", "delta": 0.5 }
          ]
        }
