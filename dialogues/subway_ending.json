        {
          "text": "「你知道我在想什么？」",
          "next_node": "tb_stranger_meta",
          "condition": { "type": "flag", "flag": "stranger_revealed", "value": true },
          "effects": []
        },
        {
          "text": "「我确定。」",
          "next_node": "tb_final",
          "effects": [
            { "type": "slider_delta", "axis": "conviction", "delta": -0.5 }
          ]
        },
        {
          "text": "「……不。」",
          "next_node": "tb_final",
          "effects": [
            { "type": "slider_delta", "axis": "hope", "delta": -0.5 }
          ]
        }
      ]
    },
    "tb_final": {
      "speaker": "Narrator",
      "text": "You step into the rain.\nThe street is empty.\nThe night never ends.",
      "choices": [
        {
          "text": "— Turn Back —",
          "next_node": null,
          "effects": [
            { "type": "set_flag", "flag": "ending_turn_back", "value": true }
