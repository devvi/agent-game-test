    "kw_stranger_meta": {
      "speaker": "Stranger",
      "text": "下次再见。\n……或者说，\n下次再见自己。",
      "choices": [
        {
          "text": "「再见。」",
          "next_node": "kw_train",
          "effects": [
            { "type": "slider_delta", "axis": "hope", "delta": 1.0 }
