        {
          "text": "— Keep Walking —",
          "next_node": null,
          "effects": [
            { "type": "set_flag", "flag": "ending_keep_walking", "value": true }
          ]
        }
      ]
    },
    "tb_arrive": {
      "speaker": "Narrator",
      "text": "The station entrance gapes.\nYou stop at the stairs.\nSomething holds you back.",
