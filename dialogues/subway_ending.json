    "st_final": {
      "speaker": "Narrator",
      "text": "The clock ticks: 11:48.\nThe platform hums.\nYou're still here. That's okay.",
      "choices": [
        {
          "text": "— Stay —",
          "next_node": null,
          "effects": [
            { "type": "set_flag", "flag": "ending_stay", "value": true }
