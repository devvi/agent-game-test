        {
          "text": "Reach for the gate.",
          "next_node": "tb_decision",
          "effects": [
            { "type": "slider_delta", "axis": "will", "delta": 0.5 }
          ]
        },
        {
          "text": "Pull your hand back.",
          "next_node": "tb_decision",
          "effects": [
            { "type": "slider_delta", "axis": "conviction", "delta": -0.5 }
          ]
        }
      ]
